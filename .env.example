# GitHub-integration (valfritt – utan token används oautentiserade anrop med lägre rate limit)
GITHUB_USERNAME=Stoffe101
# GITHUB_TOKEN=ghp_your_token_here

# Kontaktformulär (Resend). Utan nyckel visar formuläret ett kontrollerat
# felmeddelande med mailto-fallback – sidan kraschar inte.
# RESEND_API_KEY=re_your_key_here
# Avsändare – domänen måste vara verifierad i Resend.
# RESEND_FROM="skrra.dev Kontakt <noreply@skrra.dev>"

# Google Search Console (valfritt – utelämnas taggen helt).
# GOOGLE_SITE_VERIFICATION=your_verification_token
